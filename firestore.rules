rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is user authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: does the user match the record owner
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // User metrics: profile, water logs etc
    // Metric document ID is in format: {userId}_profile or {userId}_water
    match /users_metrics/{metricId} {
      allow read: if isAuth() && (
        metricId == request.auth.uid + "_profile" || 
        metricId == request.auth.uid + "_water" ||
        (metricId.endsWith("_profile") && (
          !('privacy' in resource.data) ||
          resource.data.privacy.isPrivate == false ||
          exists(/databases/$(database)/documents/follows/$(request.auth.uid + "_" + resource.data.userId)) &&
          get(/databases/$(database)/documents/follows/$(request.auth.uid + "_" + resource.data.userId)).data.status == "accepted"
        ))
      );
      allow write, delete: if isAuth() && (
        metricId == request.auth.uid + "_profile" || 
        metricId == request.auth.uid + "_water"
      );
    }

    // User ecosystem state
    match /users_ecosystem/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Log items containing userId field
    match /food_logs/{logId} {
      allow read, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    match /workout_logs/{logId} {
      allow read, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    match /weight_logs/{logId} {
      allow read, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    match /meal_scans/{logId} {
      allow read, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // Chat sessions: keyed by session ID, contains userId
    match /chat_sessions/{sessionId} {
      allow read, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create, update: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // AI Coaching feedback training logs
    match /TrainingLogs/{logId} {
      allow read, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // Social usernames collection
    match /usernames/{username} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Social follow system
    match /follows/{followId} {
      allow read: if isAuth() && (resource.data.followerId == request.auth.uid || resource.data.followingId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.followerId == request.auth.uid;
      allow update: if isAuth() && resource.data.followingId == request.auth.uid && request.resource.data.status == "accepted";
      allow delete: if isAuth() && (resource.data.followerId == request.auth.uid || resource.data.followingId == request.auth.uid);
    }

    // Social blocking system
    match /blocks/{blockId} {
      allow read: if isAuth() && resource.data.blockerId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.blockerId == request.auth.uid;
      allow delete: if isAuth() && resource.data.blockerId == request.auth.uid;
    }

    // Social activity feed items
    match /social_activities/{activityId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || 
        (exists(/databases/$(database)/documents/follows/$(request.auth.uid + "_" + resource.data.userId)) &&
         get(/databases/$(database)/documents/follows/$(request.auth.uid + "_" + resource.data.userId)).data.status == "accepted")
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
